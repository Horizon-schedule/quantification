# StopQuant 环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# ---------- 应用 ----------
HTTP_PORT=80
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=stop-quant-change-me-in-production
LOG_LEVEL=INFO

# ---------- 数据库（本地默认 SQLite，生产用 RDS MySQL）----------
# 方式一：分项配置（推荐 RDS）
DB_TYPE=sqlite
# DB_TYPE=mysql
# DB_HOST=rm-xxxxxxxx.mysql.rds.aliyuncs.com
# DB_PORT=3306
# DB_USER=stopquant
# DB_PASSWORD=YourStrongPassword123
# DB_NAME=stopquant

# 方式二：完整 URL（PostgreSQL / MySQL）
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/stopquant?charset=utf8mb4

# ---------- API 限频 ----------
API_REQUEST_INTERVAL=0.5
API_TIMEOUT=15
API_MAX_RETRIES=3

# ---------- 回测 ----------
BACKTEST_INITIAL_CAPITAL=200000
BACKTEST_COMMISSION=0.0003
BACKTEST_STAMP_TAX=0.001
BACKTEST_BENCHMARK=000300

# ---------- 盯盘 ----------
MONITOR_POLL_INTERVAL=10

# ============================================================
# 免费数据源配置（全部无需 API Key）
# 平台对照表见 docs/DATA_SOURCES.md
# ============================================================

# 主数据源：eastmoney（东方财富公开接口，推荐）
DATA_SOURCE_PRIMARY=eastmoney

# 备用数据源（预留 baostock / akshare，暂未启用）
DATA_SOURCE_FALLBACK=none

# 各数据模块开关（true / false）
ENABLE_MINUTE_KLINE=true
ENABLE_FINANCIAL_STATEMENTS=true
ENABLE_ANALYST_FORECAST=true
ENABLE_NORTHBOUND=true
ENABLE_DRAGON_TIGER=true
ENABLE_SHAREHOLDER=true
ENABLE_CNINFO_LINK=true
ENABLE_LEVEL2=false

# 扩展数据请求间隔（秒）
EXTENDED_API_INTERVAL=0.6
