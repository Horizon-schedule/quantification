# ============================================================
# StopQuant - ECS + 阿里云 RDS MySQL 部署配置
# 使用方法: cp .env.example .env  然后修改下方参数
# ============================================================

# ---------- Web 服务 ----------
HTTP_PORT=80
SECRET_KEY=请替换为32位以上随机字符串
LOG_LEVEL=INFO
TZ=Asia/Shanghai

# ---------- RDS MySQL（推荐方式：分项配置）----------
DB_TYPE=mysql
# 内网地址（ECS 与 RDS 同 VPC 时用内网，更快更安全）
DB_HOST=rm-xxxxxxxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=stopquant
DB_PASSWORD=your_rds_password
DB_NAME=stopquant

# ---------- 或使用完整连接 URL（二选一，设了 DATABASE_URL 则忽略上面分项）----------
# DATABASE_URL=mysql+pymysql://stopquant:your_password@rm-xxxxxxxx.mysql.rds.aliyuncs.com:3306/stopquant?charset=utf8mb4

# ---------- 回测默认参数 ----------
BACKTEST_INITIAL_CAPITAL=200000
BACKTEST_COMMISSION=0.0003

# ---------- API 限频（合规，勿调太低）----------
API_REQUEST_INTERVAL=0.5

# ---------- 告警（可选）----------
ALERT_SOUND=false
ALERT_WECHAT_ENABLED=false
WECHAT_WEBHOOK=

# ---------- 盯盘轮询间隔（秒）----------
MONITOR_POLL_INTERVAL=10
